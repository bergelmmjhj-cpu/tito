{
  "name": "timeclock-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "index.js",
  "scripts": {
    "start": "node --env-file-if-exists=.env index.js",
    "dev": "node --env-file-if-exists=.env --watch index.js",
    "test": "node --test",
    "seed:admin": "node --env-file-if-exists=.env scripts/createAdmin.js",
    "promote:admin": "node --env-file-if-exists=.env scripts/promoteUserToAdmin.js",
    "dedupe:hotels": "node --env-file-if-exists=.env scripts/dedupeHotels.js --dry-run",
    "dedupe:hotels:apply": "node --env-file-if-exists=.env scripts/dedupeHotels.js --apply",
    "bulk:ack": "node --env-file-if-exists=.env scripts/bulk-acknowledge.js --dry-run",
    "bulk:ack:apply": "node --env-file-if-exists=.env scripts/bulk-acknowledge.js --apply"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.3.2",
    "google-auth-library": "^9.6.0",
    "pg": "^8.11.3"
  }
}
