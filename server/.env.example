# Server port (optional, defaults to 3000)
PORT=3000

# Bootstrap admin user (created on startup only when no admin exists)
ADMIN_EMAIL=admin@hotel.local
ADMIN_PASSWORD=<set-strong-password>
ADMIN_FIRST_NAME=System
ADMIN_LAST_NAME=Admin
# Optional override for admin staff ID
ADMIN_STAFF_ID=A1000

# Backward-compatible aliases (optional)
# DEFAULT_ADMIN_EMAIL=admin@hotel.local
# DEFAULT_ADMIN_PASSWORD=<set-strong-password>

# Require browser geolocation payload on attendance actions by default
REQUIRE_ATTENDANCE_LOCATION=true

# Optional strict enforcement: block clock-in when outside assigned workplace geofence radius
ENFORCE_CLOCKIN_GEOFENCE=false
